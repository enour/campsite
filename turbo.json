{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.*"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".next/cache/**"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_*", "VERCEL_*"]
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "outputs": ["coverage/**"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [".eslintcache"]
    },
    "lint:fix": {
      "outputs": [".eslintcache"]
    },
    "analyze": {
      "dependsOn": ["^build"],
      "outputs": [".next/analyze/**"]
    },
    "sentry:sourcemaps": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
